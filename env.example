# ===========================================
# VoiceAI Website Environment Configuration
# ===========================================

# ===========================================
# Email Service Configuration (Resend)
# ===========================================
# Get your API key from https://resend.com after signing up
# Add RESEND_API_KEY to your .env.local file
RESEND_API_KEY=

# ===========================================
# Website Domain Configuration
# ===========================================
# Your website domain (used for the 'from' email address)
NEXT_PUBLIC_SITE_DOMAIN=pixpoc.ai
NEXT_PUBLIC_SITE_URL=https://pixpoc.ai

# ===========================================
# reCAPTCHA Configuration
# ===========================================
# Get these from Google reCAPTCHA console: https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_PROJECT_ID=

# ===========================================
# PixPoc Voice API Configuration
# ===========================================
# JWT secret for authentication (use a strong, random secret)
PIXPOC_JWT_SECRET=your_secure_secret_key_your_secure_secret_keey

# Token expiration time in minutes (default: 10 minutes)
PIXPOC_TOKEN_MINUTES=10

# AI assistant gender (affects AI assistant name and voice selection)
# Options: male, female
PIXPOC_GENDER=male

# Phone number to call from (must be verified with your provider)
PIXPOC_FROM_NUMBER=+19152855140

# PixPoc API server URL
PIXPOC_SERVER_URL=https://lxjihu6hrj.execute-api.ap-south-1.amazonaws.com/dev

# Maximum call duration in seconds (default: 300 seconds = 5 minutes)
PIXPOC_MAX_CALL_DURATION=300

# ===========================================
# Next.js Configuration
# ===========================================
# Node environment (development, production, test)
NODE_ENV=development

# ===========================================
# Optional: Database Configuration
# ===========================================
# Uncomment and configure if you add a database
# DATABASE_URL=
# DATABASE_HOST=
# DATABASE_PORT=
# DATABASE_NAME=
# DATABASE_USER=
# DATABASE_PASSWORD=

# ===========================================
# Optional: Analytics Configuration
# ===========================================
# Uncomment and configure if you add analytics
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
# NEXT_PUBLIC_MIXPANEL_TOKEN=
# NEXT_PUBLIC_AMPLITUDE_API_KEY=

# ===========================================
# Optional: Monitoring Configuration
# ===========================================
# Uncomment and configure if you add monitoring
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# ===========================================
# Optional: CDN Configuration
# ===========================================
# Uncomment and configure if you use a CDN
# NEXT_PUBLIC_CDN_URL=
# CLOUDFLARE_API_TOKEN=

# ===========================================
# Security Headers (Optional)
# ===========================================
# Uncomment and configure for additional security
# SECURITY_HEADERS_ENABLED=true
# CSP_NONCE_SECRET=your_csp_nonce_secret

# ===========================================
# Rate Limiting (Optional)
# ===========================================
# Uncomment and configure for custom rate limiting
# RATE_LIMIT_REDIS_URL=
# RATE_LIMIT_MAX_REQUESTS=100
# RATE_LIMIT_WINDOW_MS=900000

# ===========================================
# Development Tools (Optional)
# ===========================================
# Uncomment for development debugging
# DEBUG=true
# VERBOSE_LOGGING=true
# MOCK_EMAIL_SERVICE=true

# ===========================================
# Notes
# ===========================================
# 1. Never commit this file to version control
# 2. Copy this file to .env.local for local development
# 3. Set up environment variables in your hosting platform for production
# 4. Use strong, unique secrets for production
# 5. Regularly rotate API keys and secrets
# 6. Test all integrations after changing environment variables
