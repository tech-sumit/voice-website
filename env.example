# Create this file as .env.local with actual values for your environment

# Site URL with domain (required for webhooks)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# reCAPTCHA settings
# Option 1: Direct verification (recommended, simpler)
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# PanditaAI settings
PANDITA_JWT_SECRET=your-jwt-secret
PANDITA_SERVER_URL=https://api.panditaai.com
PANDITA_FROM_NUMBER=+19704448778
PANDITA_GENDER=female
PANDITA_MAX_CALL_DURATION=300
PANDITA_TOKEN_MINUTES=10
PANDITA_TIMEOUT=30

# Email service (Resend)
RESEND_API_KEY=your-resend-api-key
NEXT_PUBLIC_SITE_DOMAIN=your-domain.com 